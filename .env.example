ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
NOVEL_CUSTOM_API_KEY=

# 四角色独立路由：写/策/改/审各用不同供应商
# custom 表示任意 OpenAI-compatible /chat/completions 通用接口。
NOVEL_PROSE_PROVIDER=anthropic
NOVEL_ASSIST_PROVIDER=anthropic
NOVEL_REVISE_PROVIDER=anthropic
NOVEL_CRITIC_PROVIDER=deepseek

NOVEL_CLAUDE_MODEL=claude-opus-4-6
NOVEL_CLAUDE_MAX_TOKENS=8000
NOVEL_CLAUDE_TEMPERATURE=0.85
NOVEL_ANTHROPIC_STREAM_THRESHOLD_TOKENS=20000

# DEEPSEEK_BASE_URL=https://api.deepseek.com   # 可自定义 DeepSeek API 端点，默认 https://api.deepseek.com
NOVEL_DEEPSEEK_MODEL=deepseek-v4-pro
NOVEL_DEEPSEEK_MAX_TOKENS=32000
NOVEL_DEEPSEEK_REASONING_EFFORT=max
NOVEL_DEEPSEEK_THINKING=enabled

# 策划类长文本自动压缩护栏。世界观/大纲/角色等输入会先分块截断，再限制最终 prompt。
NOVEL_PLANNING_PROMPT_CHAR_LIMIT=28000
# 总纲生成/改稿输出过长时会自动续写。0 表示关闭续写。
NOVEL_PLANNING_CONTINUATION_ROUNDS=3
# 可选：单轮总纲输出 token 上限；留空时按当前模型路由自动取较大值。
NOVEL_OUTLINE_MAX_TOKENS=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
NOVEL_OPENROUTER_PROSE_MODEL=openrouter/auto
NOVEL_OPENROUTER_ASSIST_MODEL=openrouter/auto
NOVEL_OPENROUTER_REVISE_MODEL=openrouter/auto
NOVEL_OPENROUTER_CRITIC_MODEL=openrouter/auto
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=Novel Writing System

# 通用 OpenAI-Compatible 接口：适配 SiliconFlow、Moonshot、智谱、百炼、One API、LiteLLM 等。
# Base URL 填到 /v1 级别，不要包含 /chat/completions。
NOVEL_CUSTOM_PROVIDER_NAME=通用接口
NOVEL_CUSTOM_BASE_URL=
NOVEL_CUSTOM_MODEL=
NOVEL_CUSTOM_PROSE_MODEL=
NOVEL_CUSTOM_ASSIST_MODEL=
NOVEL_CUSTOM_REVISE_MODEL=
NOVEL_CUSTOM_CRITIC_MODEL=
NOVEL_CUSTOM_RETRY_INPUT_CHAR_LIMIT=24000
NOVEL_CUSTOM_RETRY_MAX_TOKENS=6000

NOVEL_OLLAMA_MODEL=qwen3:8b
NOVEL_OLLAMA_URL=http://localhost:11434/api/generate
NOVEL_OLLAMA_TIMEOUT=120
NOVEL_OPENAI_TIMEOUT_SECONDS=120
NOVEL_OLLAMA_NUM_PREDICT=4096
NOVEL_OLLAMA_TEMPERATURE=0.2
NOVEL_OLLAMA_TOP_P=0.9

# 可选：费用估算价格，单位为 1M tokens。
# Anthropic / OpenRouter 示例为 USD；DeepSeek 官方平台为人民币 CNY，并区分输入缓存命中/未命中。
NOVEL_COST_ANTHROPIC_CLAUDE_OPUS_4_6_INPUT_PER_M=15
NOVEL_COST_ANTHROPIC_CLAUDE_OPUS_4_6_OUTPUT_PER_M=75
NOVEL_COST_OPENROUTER_ANTHROPIC_CLAUDE_OPUS_4_6_INPUT_PER_M=15
NOVEL_COST_OPENROUTER_ANTHROPIC_CLAUDE_OPUS_4_6_OUTPUT_PER_M=75
NOVEL_COST_DEEPSEEK_DEEPSEEK_V4_FLASH_INPUT_CACHE_HIT_PER_M=0.02
NOVEL_COST_DEEPSEEK_DEEPSEEK_V4_FLASH_INPUT_CACHE_MISS_PER_M=1
NOVEL_COST_DEEPSEEK_DEEPSEEK_V4_FLASH_OUTPUT_PER_M=2
NOVEL_COST_DEEPSEEK_DEEPSEEK_V4_PRO_INPUT_CACHE_HIT_PER_M=0.025
NOVEL_COST_DEEPSEEK_DEEPSEEK_V4_PRO_INPUT_CACHE_MISS_PER_M=3
NOVEL_COST_DEEPSEEK_DEEPSEEK_V4_PRO_OUTPUT_PER_M=6

# mock / auto / real
NOVEL_LLM_MODE=auto

# mock / auto
NOVEL_RAG_MODE=auto
NOVEL_STYLE_PROFILE=
NOVEL_EMBED_MODEL=D:\huggingface\bge-m3

HF_ENDPOINT=https://hf-mirror.com
HF_HUB_DISABLE_XET=1
